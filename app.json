{
  "expo": {
    "name": "Prototype App",
    "slug": "prototype-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/prototype_logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/prototype_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rmtechsolution.prototypeapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.rmtechsolution.prototypeapp",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/prototype_logo.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "POST_NOTIFICATIONS",
        "INTERNET",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN"
      ]
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "eaa2e69a-390e-40a4-a107-2718d48a50fe"
      }
    },
    "owner": "rm-tech-solution",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/eaa2e69a-390e-40a4-a107-2718d48a50fe",
      "enabled": true,
      "checkAutomatically": "ON_LOAD"
    },
    "notification": {
      "icon": "./assets/prototype_logo.png",
      "color": "#ffffff"
    },
    "rmtech": {
        "merchantId": "9",
        "baseUrl": "https://api.rmtechsolution.com/"
      }
  }
}
