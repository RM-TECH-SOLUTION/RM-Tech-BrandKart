{
  "expo": {
    "name": "RM Tech BrandKart",
    "slug": "rm-tech-brandkart",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/appicon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/adaptive-foreground-rm-symbol-v2.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b1020"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rmtechsolution.rmtechbrandkart",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.rmtechsolution.rmtechbrandkart",
      "googleServicesFile": "./google-services.json",
      "splash": {
        "image": "./assets/adaptive-foreground-rm-symbol-v2.png",
        "resizeMode": "contain",
        "backgroundColor": "#0b1020"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-foreground-rm-symbol-v2.png",
        "backgroundColor": "#0b1020"
      },
      "permissions": [
        "POST_NOTIFICATIONS",
        "INTERNET",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN"
      ]
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0b1020",
          "image": "./assets/adaptive-foreground-rm-symbol-v2.png",
          "imageWidth": 220
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "eaa2e69a-390e-40a4-a107-2718d48a50fe"
      }
    },
    "owner": "rm-tech-solution",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/eaa2e69a-390e-40a4-a107-2718d48a50fe",
      "enabled": true,
      "checkAutomatically": "ON_LOAD"
    },
    "notification": {
      "icon": "./assets/adaptive-icon-rm.png",
      "color": "#ffffff"
    },
    "rmtech": {
        "merchantId": "9",
        "baseUrl": "https://api.rmtechsolution.com/"
      }
  }
}
